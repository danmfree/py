import socket
import struct
from picamera2 import Picamera2
import cv2
import numpy as np
import pytesseract

HOST = "0.0.0.0"
PORT = 5000

class MCBDectection:

    def __init__(self):
        self.result = ""
        self.image = None
        self.frame = None
    
    def detect(self, roiX=None, roiY=None, roiWidth=None, roiHeight=None):

        #resize image
        resized = self.frame

        if resized is None:
            resized = cv2.imread("capture.jpg")

        if (roiX is not None and roiY is not None and roiWidth is not None and roiHeight is not None):
            print ("Using Manual Roi")

            croppedMcb = resized[roiY:roiY + roiHeight,roiX:roiX + roiWidth]
            croppedText = croppedMcb
        
        else:
            print ("Using Automatic Detection")

            # Convert to grayscale
            gray = cv2.cvtColor(resized, cv2.COLOR_RGB2GRAY)

            #blur image
            blurred = cv2.GaussianBlur(gray, (5, 5), 0)

            #detect edges
            edges = cv2.Canny(blurred, 15, 150)

            #inntialize kernel for morphological operations
            kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (15, 15))

            #perform morphological closing to fill gaps in edges
            closed = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel)

            # apply contours 
            contours, _ = cv2.findContours(closed, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

            maxArea = 0
            mcbContour = None   

            for contour in contours:
                area = cv2.contourArea(contour)
                if area > 5000 and area > maxArea:
                    maxArea = area
                    mcbContour = contour
        
            if mcbContour is None:
                print("No MCB detected.")
                return None
        
            # Get bounding box of the detected MCB
            x, y, w, h = cv2.boundingRect(mcbContour)

            croppedMcb = resized[y:y+h, x:x+w  ]

            # text Roi
            textX = int(w * 0.15)
            textY = int(h * 0.33)
            textW = int(w * 0.35)
            textH = int(h * 0.33)

            croppedText = croppedMcb[textY:textY+textH, textX:textX+textW]

        #image processing

        croppedGray = cv2.cvtColor(croppedText, cv2.COLOR_RGB2GRAY)

        #denoise image
        denoised = cv2.bilateralFilter(croppedGray, 9, 75, 75)

        croppedBlurred = cv2.GaussianBlur(denoised, (3, 3), 0)

        sharp = cv2.addWeighted(croppedGray, 1.5, croppedBlurred, -0.5, 0)
        
        # blakc and white 
        _, bw = cv2.threshold(sharp, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)

        # OCR 

        text = pytesseract.image_to_string(bw, config='--psm 6')

        self.result = text
        self.image = bw

        print("Detected text:", text)

        #Display the processed image
        #cv2.imshow("Processed Image", bw)

        cv2.waitKey(0)
        cv2.destroyAllWindows()

        return text


# TCP

detector = MCBDectection()

server = socket.socket(socket.AF_INET,socket.SOCK_STREAM) 

server.bind((HOST,PORT))

server.listen(1)

print("Waiting for Laptop...")

conn,addr = server.accept()

print("Connected:", addr)

picam2 = Picamera2()
picam2.start()

while True:
    command = conn.recv(1024).decode()

    if command == "CAPTURE":
        print("Capture command received")

        frame = picam2.capture_array()

        resized = cv2.imread("/home/aeis/Desktop/HI.jpg") # get rid of this
        #resize image
        resized = cv2.resize(resized, (1920, 1080)) # change this

        detector.frame = resized

        cv2.imwrite("capture.jpg", resized)

        success, encoded = cv2.imencode(".jpg", resized)

        imageBytes = encoded.tobytes()

        conn.sendall(struct.pack(">I", len(imageBytes)))

        conn.sendall(imageBytes)

        print("Image Sent")

    elif command == "AUTO":
        detector.detect()
        conn.send(b"DONE")

    elif command.startswith("ROI:"):
        coords = command[4:].split(",") 

        roiX = int(coords[0])
        roiY = int(coords[1])
        roiWidth = int(coords[2])
        roiHeight = int(coords[3])

        detector.detect(roiX,roiY,roiWidth,roiHeight)

        conn.send(b"DONE")

    elif command == "READ":
        print("Sending OCR result") 

        conn.send(detector.result.encode()) 

    elif command == "EXIT":
        picam2.stop()
        break

conn.close()
server.close()
